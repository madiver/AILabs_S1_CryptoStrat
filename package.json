{
  "name": "ailabs-s1-cryptostrat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A real-time crypto trading dashboard built end-to-end with AI as a thinking partner.",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "test": "vitest run --config frontend/vite.config.ts",
    "test:e2e": "playwright test -c frontend/playwright.config.ts",
    "typecheck": "tsc -p frontend/tsconfig.json --noEmit",
    "check:node": "node --version && npm --version"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lightweight-charts": "^5.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14"
  }
}
